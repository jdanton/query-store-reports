{
  "name": "query-store-reports",
  "displayName": "SQL Server Query Store Reports",
  "description": "A cross-platform VS Code extension that brings SQL Server Management Studio's Query Store report suite directly into VS Code. Works on macOS, Linux, and Windows.",
  "version": "0.4.0",
  "publisher": "query-store-reports",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "ms-mssql.mssql"
  ],
  "activationEvents": [
    "onView:objectExplorer"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdanton/query-store-reports.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "queryStore.topResources",
        "title": "Top Resource Consuming Queries",
        "category": "Query Store"
      },
      {
        "command": "queryStore.regressed",
        "title": "Regressed Queries",
        "category": "Query Store"
      },
      {
        "command": "queryStore.highVariation",
        "title": "Queries with High Variation",
        "category": "Query Store"
      },
      {
        "command": "queryStore.waitStats",
        "title": "Overall Wait Statistics",
        "category": "Query Store"
      },
      {
        "command": "queryStore.forcedPlans",
        "title": "Forced Plans",
        "category": "Query Store"
      },
      {
        "command": "queryStore.overallConsumption",
        "title": "Overall Resource Consumption",
        "category": "Query Store"
      }
    ],
    "submenus": [
      {
        "id": "queryStore.submenu",
        "label": "Query Store"
      }
    ],
    "configuration": {
      "title": "Query Store Reports",
      "properties": {
        "queryStoreReports.defaultMetric": {
          "type": "string",
          "default": "duration",
          "enum": [
            "duration",
            "cpu",
            "logicalReads",
            "logicalWrites",
            "physicalReads",
            "memory",
            "rowcount"
          ],
          "enumDescriptions": [
            "Duration (ms)",
            "CPU Time (ms)",
            "Logical IO Reads",
            "Logical IO Writes",
            "Physical IO Reads",
            "Memory (KB)",
            "Row Count"
          ],
          "description": "Default metric for the Top Resource Consuming Queries report."
        },
        "queryStoreReports.defaultTimeWindow": {
          "type": "string",
          "default": "1h",
          "enum": [
            "1h",
            "4h",
            "24h",
            "7d",
            "30d"
          ],
          "enumDescriptions": [
            "Last 1 hour",
            "Last 4 hours",
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days"
          ],
          "description": "Default time window for reports (Top Resources, Regressed recent period, High Variation, Wait Stats)."
        },
        "queryStoreReports.defaultRowCount": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 200,
          "description": "Default number of rows to return in query reports."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "queryStore.topResources"
        },
        {
          "command": "queryStore.regressed"
        },
        {
          "command": "queryStore.highVariation"
        },
        {
          "command": "queryStore.waitStats"
        },
        {
          "command": "queryStore.forcedPlans"
        },
        {
          "command": "queryStore.overallConsumption"
        }
      ],
      "view/item/context": [
        {
          "submenu": "queryStore.submenu",
          "when": "view == objectExplorer && viewItem =~ /\\btype=(Database)\\b/",
          "group": "queryStore@1"
        }
      ],
      "queryStore.submenu": [
        {
          "command": "queryStore.topResources",
          "group": "1_reports@1"
        },
        {
          "command": "queryStore.regressed",
          "group": "1_reports@2"
        },
        {
          "command": "queryStore.highVariation",
          "group": "1_reports@3"
        },
        {
          "command": "queryStore.waitStats",
          "group": "1_reports@4"
        },
        {
          "command": "queryStore.forcedPlans",
          "group": "1_reports@5"
        },
        {
          "command": "queryStore.overallConsumption",
          "group": "1_reports@6"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs --production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.8.9",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
